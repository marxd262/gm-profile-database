---
/**
 * Base Layout
 * Provides the HTML structure, head, and navigation for all pages
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  showDownloadAll?: boolean;
  downloadManifest?: string[];
}

const {
  title = 'Gaggimate Profile Store',
  description = 'Community catalog for Gaggimate espresso brewing profiles',
  showDownloadAll = false,
  downloadManifest = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/gm-profile-database/favicon.svg" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    
    <title>{title}</title>
    
    <!-- Theme initialization script (runs before page render to prevent flash) -->
    <script is:inline>
      const STORAGE_KEY = 'gaggimate-daisyui-theme';
      const DEFAULT_THEME = 'light';
      const AVAILABLE_THEMES = ['light', 'dark', 'coffee', 'nord'];
      
      try {
        const stored = localStorage.getItem(STORAGE_KEY);
        const theme = (stored && AVAILABLE_THEMES.includes(stored)) ? stored : DEFAULT_THEME;
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', DEFAULT_THEME);
      }
    </script>
  </head>
  <body class="bg-base-300 min-h-screen">
    <div class="flex min-h-screen flex-col">
      <!-- Skip link for accessibility -->
      <a href="#main" class="skip-link">Skip to main content</a>

      <!-- Header -->
      <header class="border-b-2 border-base-300 bg-base-100">
        <div class="mx-auto flex items-center justify-between px-4 py-4 lg:py-6 xl:container">
          <!-- Wordmark -->
          <a href="/gm-profile-database/" class="font-logo text-3xl font-light text-base-content hover:opacity-80 transition-opacity">
            <span class="font-semibold">GAGGI</span>MATE
            <span class="text-base font-normal text-base-content/50 ml-2">Profiles</span>
          </a>

          <div class="flex items-center gap-2">
            <!-- GitHub link -->
            <a
              href="https://github.com/marxd262/gm-profile-database"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="View on GitHub"
              class="btn btn-sm btn-circle bg-transparent border-none hover:bg-base-content/10"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="fill-current">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>

            <!-- Theme selector -->
            <div class="dropdown dropdown-end">
              <label tabindex="0" class="btn btn-sm btn-circle bg-transparent border-none hover:bg-base-content/10" aria-label="Select theme">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-5 h-5 stroke-current">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                </svg>
              </label>
              <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box shadow-lg w-48 mt-2 p-2">
                <li><button data-theme="light" class="theme-option">☀️ Light</button></li>
                <li><button data-theme="dark" class="theme-option">🌙 Dark</button></li>
                <li><button data-theme="coffee" class="theme-option">☕ Coffee</button></li>
                <li><button data-theme="nord" class="theme-option">❄️ Nord</button></li>
              </ul>
            </div>
          </div>
        </div>
      </header>

      <!-- Main content -->
      <main id="main" class="flex-1 mx-auto w-full px-4 py-6 lg:p-8 xl:container">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t-2 border-base-content/10 py-3 text-sm font-medium text-base-content/60">
        <div class="mx-auto flex items-center justify-between px-4 xl:container">
          <span>
            Gaggimate Profile Store &mdash;
            <a
              href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
              class="text-primary hover:text-primary/80 transition font-medium"
              target="_blank"
              rel="noopener noreferrer"
            >CC BY-NC-SA 4.0</a>
          </span>
          <div class="flex items-center gap-3">
            {showDownloadAll && (
              <button
                id="download-all-btn"
                type="button"
                data-manifest={JSON.stringify(downloadManifest)}
                aria-label="Download all profiles as ZIP"
                title="Download all profiles"
                class="flex items-center gap-1.5 opacity-40 hover:opacity-80 hover:text-base-content transition cursor-pointer text-xs"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                <span>download all</span>
              </button>
            )}
            <a
              href="https://github.com/marxd262/gm-profile-database"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="View on GitHub"
              class="hover:text-base-content transition"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="fill-current">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          </div>
        </div>
      </footer>
    </div>

    <!-- Theme switching script -->
    <script>
      import { setTheme } from '@/utils/theme';
      
      document.querySelectorAll('.theme-option').forEach(button => {
        button.addEventListener('click', (e) => {
          const theme = (e.target as HTMLElement).dataset.theme;
          if (theme) {
            setTheme(theme);
          }
        });
      });
    </script>
  </body>
</html>
