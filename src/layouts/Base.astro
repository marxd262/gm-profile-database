---
/**
 * Base Layout
 * Provides the HTML structure, head, and navigation for all pages
 */
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Gaggimate Profile Store',
  description = 'Community catalog for Gaggimate espresso brewing profiles'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/gm-profile-database/favicon.svg" />
    
    <title>{title}</title>
    
    <!-- Theme initialization script (runs before page render to prevent flash) -->
    <script is:inline>
      // Initialize theme immediately
      const STORAGE_KEY = 'gaggimate-daisyui-theme';
      const DEFAULT_THEME = 'light';
      const AVAILABLE_THEMES = ['light', 'dark', 'coffee', 'nord'];
      
      try {
        const stored = localStorage.getItem(STORAGE_KEY);
        const theme = (stored && AVAILABLE_THEMES.includes(stored)) ? stored : DEFAULT_THEME;
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', DEFAULT_THEME);
      }
    </script>
  </head>
  <body>
    <!-- Skip links for accessibility -->
    <a href="#main" class="skip-link">Skip to main content</a>
    
    <!-- Header/Navigation -->
    <header class="navbar bg-base-200 shadow-sm">
      <div class="container mx-auto px-4">
        <div class="flex-1">
          <a href="/gm-profile-database/" class="btn btn-ghost text-xl font-bold">
            Gaggimate Profiles
          </a>
        </div>
        
        <div class="flex-none gap-2">
          <!-- Theme selector -->
          <div class="dropdown dropdown-end">
            <label tabindex="0" class="btn btn-ghost btn-circle" aria-label="Select theme">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-5 h-5 stroke-current">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </label>
            <ul tabindex="0" class="dropdown-content menu p-2 shadow-lg bg-base-100 rounded-box w-52 mt-4">
              <li><button data-theme="light" class="theme-option">☀️ Light</button></li>
              <li><button data-theme="dark" class="theme-option">🌙 Dark</button></li>
              <li><button data-theme="coffee" class="theme-option">☕ Coffee</button></li>
              <li><button data-theme="nord" class="theme-option">❄️ Nord</button></li>
            </ul>
          </div>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main id="main" class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer footer-center p-10 bg-base-200 text-base-content mt-16">
      <div>
        <p class="font-bold">Gaggimate Profile Store</p>
        <p>Community catalog for espresso brewing profiles</p>
        <p class="text-sm opacity-70">
          Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" class="link" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a>
        </p>
      </div>
      <div class="grid grid-flow-col gap-4">
        <a href="https://github.com/marxd262/gm-profile-database" target="_blank" rel="noopener noreferrer" class="link" aria-label="View on GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="fill-current">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </footer>

    <!-- Theme switching script -->
    <script>
      import { setTheme } from '@/utils/theme';
      
      // Theme switcher
      document.querySelectorAll('.theme-option').forEach(button => {
        button.addEventListener('click', (e) => {
          const theme = e.target.dataset.theme;
          if (theme) {
            setTheme(theme);
          }
        });
      });
    </script>
  </body>
</html>
