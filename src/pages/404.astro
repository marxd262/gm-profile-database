---
/**
 * 404 Not Found Page
 */
import Base from '@/layouts/Base.astro';
---

<Base title="Page Not Found - Gaggimate Profile Store">
  <div class="hero min-h-[60vh]">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <div class="text-9xl font-bold text-primary mb-4">404</div>
        <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
        <p class="mb-6">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="flex gap-4 justify-center">
          <a href="/gm-profile-database/" class="btn btn-primary">
            Go Home
          </a>
          <a href="https://github.com/marxd262/gm-profile-database" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</Base>
